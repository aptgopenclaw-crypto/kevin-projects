 grep -h "Tests run:" backend/target/surefire-reports/*.txt | awk -F'[:,]' 'BEGIN{r=f=e=s=0}{r+=$2; f+=$4; e+=$6; s+=$8} END{print "Total: run="r" failures="f" errors="e" skipped="s}' > /tmp/totals.txt
